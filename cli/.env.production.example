# Production CLI configuration for destiny-repository.
# Copy to `.env.production` and fill in placeholder values before running CLI
# commands with `--env production`.

AUTH_PROVIDER=keycloak

# Keycloak base URL for the production realm.
KEYCLOAK_URL=https://<prod-keycloak-host>
KEYCLOAK_REALM=destiny
KEYCLOAK_CLIENT_ID=destiny-auth-client

DESTINY_REPOSITORY_URL=https://api.evidence-repository.org
