@prefix evrepo: <https://vocab.evidence-repository.org/> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# SHACL Shapes for Evidence Repository Core Vocabulary
#
# Derived from evrepo-core.ttl OWL class/property definitions.
# Structural object properties (has*) require at least one value.
# =============================================================================

# --- Node Shapes ---

evrepo:LinkedDataEnhancementShape a sh:NodeShape ;
    sh:targetClass evrepo:LinkedDataEnhancement ;
    sh:property evrepo:hasInvestigationPropertyShape .

evrepo:InvestigationShape a sh:NodeShape ;
    sh:targetClass evrepo:Investigation ;
    sh:property evrepo:hasFindingPropertyShape .

evrepo:FindingShape a sh:NodeShape ;
    sh:targetClass evrepo:Finding ;
    sh:property evrepo:hasContextPropertyShape ,
        evrepo:hasOutcomePropertyShape ,
        evrepo:evaluatesPropertyShape ,
        evrepo:comparedToPropertyShape ,
        evrepo:hasArmDataPropertyShape ,
        evrepo:hasEffectEstimatePropertyShape .

evrepo:ContextShape a sh:NodeShape ;
    sh:targetClass evrepo:Context .

evrepo:OutcomeShape a sh:NodeShape ;
    sh:targetClass evrepo:Outcome .

evrepo:ConditionShape a sh:NodeShape ;
    sh:targetClass evrepo:Condition .

evrepo:InterventionShape a sh:NodeShape ;
    sh:targetClass evrepo:Intervention .

evrepo:ControlConditionShape a sh:NodeShape ;
    sh:targetClass evrepo:ControlCondition .

evrepo:TemporalConditionShape a sh:NodeShape ;
    sh:targetClass evrepo:TemporalCondition .

evrepo:ObservedResultShape a sh:NodeShape ;
    sh:targetClass evrepo:ObservedResult ;
    sh:property evrepo:forConditionPropertyShape ,
        evrepo:nPropertyShape ,
        evrepo:meanPropertyShape ,
        evrepo:sdPropertyShape ,
        evrepo:sePropertyShape ,
        evrepo:clusterCountPropertyShape ,
        evrepo:iccPropertyShape ,
        evrepo:preMeanPropertyShape ,
        evrepo:preSdPropertyShape ,
        evrepo:eventsPropertyShape ,
        evrepo:truePositivePropertyShape ,
        evrepo:falsePositivePropertyShape ,
        evrepo:falseNegativePropertyShape ,
        evrepo:trueNegativePropertyShape ,
        evrepo:confidenceIntervalLowerPropertyShape ,
        evrepo:confidenceIntervalUpperPropertyShape .

evrepo:EffectEstimateShape a sh:NodeShape ;
    sh:targetClass evrepo:EffectEstimate ;
    sh:property evrepo:pointEstimatePropertyShape ,
        evrepo:standardErrorPropertyShape ,
        evrepo:variancePropertyShape ,
        evrepo:confidenceLevelPropertyShape ,
        evrepo:confidenceIntervalLowerPropertyShape ,
        evrepo:confidenceIntervalUpperPropertyShape ,
        evrepo:baselineAdjustedPropertyShape ,
        evrepo:clusteringAdjustedPropertyShape ,
        evrepo:effectSizeMetricPropertyShape ,
        evrepo:estimateSourcePropertyShape ,
        evrepo:derivedFromPropertyShape ,
        evrepo:forOutcomePropertyShape .

evrepo:CodingAnnotationShape a sh:NodeShape ;
    sh:targetClass evrepo:CodingAnnotation ;
    sh:property evrepo:statusPropertyShape .

evrepo:StringCodingAnnotationShape a sh:NodeShape ;
    sh:targetClass evrepo:StringCodingAnnotation .

evrepo:NumericCodingAnnotationShape a sh:NodeShape ;
    sh:targetClass evrepo:NumericCodingAnnotation .

evrepo:CodingStatusShape a sh:NodeShape ;
    sh:targetClass evrepo:CodingStatus .

evrepo:EffectSizeMetricConceptShape a sh:NodeShape ;
    sh:targetClass evrepo:EffectSizeMetricConcept .

evrepo:EstimateSourceConceptShape a sh:NodeShape ;
    sh:targetClass evrepo:EstimateSourceConcept .

# --- Structural Property Shapes (minCount 1) ---

evrepo:hasInvestigationPropertyShape sh:path evrepo:hasInvestigation ;
    sh:class evrepo:Investigation ;
    sh:minCount 1 .

evrepo:hasFindingPropertyShape sh:path evrepo:hasFinding ;
    sh:class evrepo:Finding ;
    sh:minCount 1 .

evrepo:hasContextPropertyShape sh:path evrepo:hasContext ;
    sh:class evrepo:Context ;
    sh:minCount 1 .

evrepo:hasOutcomePropertyShape sh:path evrepo:hasOutcome ;
    sh:class evrepo:Outcome ;
    sh:minCount 1 .

evrepo:hasArmDataPropertyShape sh:path evrepo:hasArmData ;
    sh:class evrepo:ObservedResult ;
    sh:minCount 1 .

evrepo:hasEffectEstimatePropertyShape sh:path evrepo:hasEffectEstimate ;
    sh:class evrepo:EffectEstimate ;
    sh:minCount 1 .

# --- Comparison Structure Property Shapes ---

evrepo:evaluatesPropertyShape sh:path evrepo:evaluates ;
    sh:class evrepo:Condition .

evrepo:comparedToPropertyShape sh:path evrepo:comparedTo ;
    sh:class evrepo:Condition .

# --- Quantitative Relationship Property Shapes ---

evrepo:forConditionPropertyShape sh:path evrepo:forCondition ;
    sh:class evrepo:Condition .

evrepo:forOutcomePropertyShape sh:path evrepo:forOutcome ;
    sh:class evrepo:Outcome .

evrepo:derivedFromPropertyShape sh:path evrepo:derivedFrom ;
    sh:class evrepo:ObservedResult .

# --- Effect Estimate Property Shapes ---

evrepo:effectSizeMetricPropertyShape sh:path evrepo:effectSizeMetric ;
    sh:class evrepo:EffectSizeMetricConcept .

evrepo:estimateSourcePropertyShape sh:path evrepo:estimateSource ;
    sh:class evrepo:EstimateSourceConcept .

evrepo:pointEstimatePropertyShape sh:path evrepo:pointEstimate ;
    sh:datatype xsd:decimal .

evrepo:standardErrorPropertyShape sh:path evrepo:standardError ;
    sh:datatype xsd:decimal .

evrepo:variancePropertyShape sh:path evrepo:variance ;
    sh:datatype xsd:decimal .

evrepo:confidenceLevelPropertyShape sh:path evrepo:confidenceLevel ;
    sh:datatype xsd:decimal .

evrepo:confidenceIntervalLowerPropertyShape sh:path evrepo:confidenceIntervalLower ;
    sh:datatype xsd:decimal .

evrepo:confidenceIntervalUpperPropertyShape sh:path evrepo:confidenceIntervalUpper ;
    sh:datatype xsd:decimal .

evrepo:baselineAdjustedPropertyShape sh:path evrepo:baselineAdjusted ;
    sh:datatype xsd:boolean .

evrepo:clusteringAdjustedPropertyShape sh:path evrepo:clusteringAdjusted ;
    sh:datatype xsd:string .

# --- Observed Result Property Shapes ---

evrepo:nPropertyShape sh:path evrepo:n ;
    sh:datatype xsd:integer .

evrepo:meanPropertyShape sh:path evrepo:mean ;
    sh:datatype xsd:decimal .

evrepo:sdPropertyShape sh:path evrepo:sd ;
    sh:datatype xsd:decimal .

evrepo:sePropertyShape sh:path evrepo:se ;
    sh:datatype xsd:decimal .

evrepo:clusterCountPropertyShape sh:path evrepo:clusterCount ;
    sh:datatype xsd:integer .

evrepo:iccPropertyShape sh:path evrepo:icc ;
    sh:datatype xsd:decimal .

evrepo:preMeanPropertyShape sh:path evrepo:preMean ;
    sh:datatype xsd:decimal .

evrepo:preSdPropertyShape sh:path evrepo:preSd ;
    sh:datatype xsd:decimal .

evrepo:eventsPropertyShape sh:path evrepo:events ;
    sh:datatype xsd:integer .

evrepo:truePositivePropertyShape sh:path evrepo:truePositive ;
    sh:datatype xsd:integer .

evrepo:falsePositivePropertyShape sh:path evrepo:falsePositive ;
    sh:datatype xsd:integer .

evrepo:falseNegativePropertyShape sh:path evrepo:falseNegative ;
    sh:datatype xsd:integer .

evrepo:trueNegativePropertyShape sh:path evrepo:trueNegative ;
    sh:datatype xsd:integer .

# --- Coding Annotation Property Shapes ---

evrepo:statusPropertyShape sh:path evrepo:status ;
    sh:class evrepo:CodingStatus .
